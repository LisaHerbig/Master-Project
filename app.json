{
  "expo": {
    "name": "Jenseits des Unmöglichen",
    "slug": "mutatio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mutatio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/hands/Image_Hand_AppIcon.jpg",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/hands/Image_Hand_AppIcon.jpg",
      "bundleIdentifier": "com.lisasila.mutatio",
      "infoPlist": {
        "NFCReaderUsageDescription": "Scanne den NFC-Sticker in deinem Buch, um den Inhalt freizuschalten."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/hands/Image_Hand_AppIcon.jpg",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lisasila.mutatio"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "react-native-nfc-manager"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
